{
	"name": "@mheob/oxlint-config",
	"version": "2.2.0",
	"private": false,
	"description": "Shared OXLint configuration",
	"keywords": [
		"config",
		"oxlint",
		"oxlintconfig"
	],
	"homepage": "https://github.com/mheob/config/tree/main/packages/oxfmt-config",
	"bugs": "https://github.com/mheob/config/issues",
	"license": "MIT",
	"author": "Alexander Böhm <tools@alex-boehm.dev>",
	"repository": {
		"type": "git",
		"url": "https://github.com/mheob/config"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run --bun tsdown --clean",
		"clean": "bun run --bun rm -rf .turbo node_modules dist",
		"format": "bun run --bun oxfmt",
		"format:check": "bun run --bun oxfmt --check",
		"lint": "bun run --bun oxlint",
		"lint:fix": "bun run --bun oxlint --fix"
	},
	"dependencies": {
		"eslint-plugin-jsonc": "^3.1.2",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-yml": "^3.3.1"
	},
	"devDependencies": {
		"@mheob/internal": "workspace:*",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"eslint-plugin-better-tailwindcss": "^4.3.2",
		"eslint-plugin-storybook": "^10.3.4",
		"oxlint": "^1.59.0"
	},
	"peerDependenciesMeta": {
		"eslint-plugin-better-tailwindcss": {
			"optional": true
		},
		"eslint-plugin-storybook": {
			"optional": true
		},
		"oxlint": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=24"
	}
}
