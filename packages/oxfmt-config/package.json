{
	"name": "@mheob/oxfmt-config",
	"version": "1.0.1",
	"private": false,
	"description": "Shared OXFmt configuration",
	"keywords": [
		"config",
		"oxfmt",
		"oxfmtconfig"
	],
	"homepage": "https://github.com/mheob/config/tree/main/packages/oxlint-config",
	"bugs": "https://github.com/mheob/config/issues",
	"license": "MIT",
	"author": "Alexander Böhm <tools@alex-boehm.dev>",
	"repository": {
		"type": "git",
		"url": "https://github.com/mheob/config"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run --bun tsdown --clean",
		"clean": "bun run --bun rm -rf .turbo node_modules dist",
		"format": "bun run --bun oxfmt",
		"format:check": "bun run --bun oxfmt --check",
		"lint": "bun run --bun oxlint",
		"lint:fix": "bun run --bun oxlint --fix"
	},
	"devDependencies": {
		"@mheob/internal": "workspace:*",
		"@mheob/oxlint-config": "workspace:*",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"oxfmt": "^0.44.0"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=24"
	}
}
