{
	"name": "@mheob/commitlint-config",
	"version": "2.0.0",
	"description": "My personal configuration for commitlint.",
	"keywords": [
		"commitlint",
		"config"
	],
	"homepage": "https://github.com/mheob/config/tree/main/packages/commitlint-config",
	"bugs": "https://github.com/mheob/config/issues",
	"license": "MIT",
	"author": "Alexander Böhm <tools@alex-boehm.dev>",
	"repository": {
		"type": "git",
		"url": "https://github.com/mheob/config"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run --bun bun build ./src/index.ts --outdir ./dist --target node --format esm",
		"clean": "bun run --bun rm -rf .turbo node_modules dist",
		"format": "bun run --bun oxfmt",
		"format:check": "bun run --bun oxfmt --check",
		"lint": "bun run --bun oxlint",
		"lint:fix": "bun run --bun oxlint --fix"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@mheob/oxfmt-config": "workspace:*",
		"@mheob/oxlint-config": "workspace:*",
		"@mheob/tsconfig": "workspace:*",
		"@types/node": "^25.5.2",
		"czg": "^1.12.0",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"@commitlint/cli": "^20.5.0",
		"czg": "^1.12.0"
	},
	"engines": {
		"node": ">=22.12.0"
	}
}
