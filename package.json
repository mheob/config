{
	"name": "@mheob/config",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"changeset": "changeset",
		"clean": "turbo run clean",
		"clean:root": "rm -rf .turbo && rm -rf node_modules",
		"cspell": "cspell .",
		"format": "turbo run format",
		"format:check": "turbo run format:check",
		"gen": "turbo run gen",
		"lint": "turbo run lint",
		"lint:fix": "turbo run lint:fix",
		"prepare": "husky",
		"release": "changeset publish",
		"typegen": "turbo run typegen",
		"version-packages": "changeset version && pnpm lint",
		"versiongen": "turbo run versiongen"
	},
	"devDependencies": {
		"@changesets/cli": "catalog:",
		"@commitlint/cli": "catalog:",
		"@cspell/dict-de-de": "catalog:",
		"@mheob/changeset-changelog": "catalog:",
		"@mheob/commitlint-config": "workspace:*",
		"@mheob/oxfmt-config": "workspace:*",
		"@mheob/oxlint-config": "workspace:*",
		"@types/node": "catalog:",
		"commitizen": "catalog:",
		"cspell": "catalog:",
		"cz-git": "catalog:",
		"husky": "catalog:",
		"lint-staged": "catalog:",
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"rimraf": "catalog:",
		"ts-node": "catalog:",
		"turbo": "catalog:",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{cjs,js,mjs,jsx,ts,tsx,json,md,mdx,yaml,yml,toml}": "oxlint --fix",
		"!(pnpm-)*.{cjs,js,mjs,jsx,ts,tsx,json,md,mdx,yaml,yml,toml}": "oxfmt"
	},
	"config": {
		"commitizen": {
			"path": "node_modules/cz-git"
		}
	},
	"engines": {
		"node": "^24.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"overrides": {
			"brace-expansion": "^1.1.13 || ^2.0.3 || ^5.0.5",
			"flatted": "^3.4.2",
			"minimatch": "^3.1.3 || ^9.0.7 || ^10.2.3",
			"picomatch": "^2.3.2 || ^4.0.4"
		}
	}
}
