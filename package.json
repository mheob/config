{
	"name": "@mheob/config",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"workspaces": [
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"changeset": "changeset",
		"clean": "turbo run clean",
		"clean:root": "rm -rf .turbo node_modules",
		"cspell": "cspell .",
		"format": "turbo run format",
		"format:check": "turbo run format:check",
		"lint": "turbo run lint",
		"lint:fix": "turbo run lint:fix",
		"prepare": "lefthook install",
		"release": "changeset publish",
		"typegen": "turbo run typegen",
		"version-packages": "changeset version && bun lint",
		"versiongen": "turbo run versiongen"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.1",
		"@commitlint/cli": "^21.2.1",
		"@cspell/dict-de-de": "^4.1.2",
		"@mheob/changeset-changelog": "^3.0.2",
		"@mheob/commitlint-config": "workspace:*",
		"@mheob/oxfmt-config": "workspace:*",
		"@mheob/oxlint-config": "workspace:*",
		"@types/node": "^26.1.1",
		"cspell": "^10.0.1",
		"czg": "^1.13.1",
		"lefthook": "^2.1.10",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"turbo": "^2.10.5",
		"typescript": "^7.0.2"
	},
	"overrides": {
		"flatted": "^3.4.2",
		"minimatch": "^10.2.3",
		"picomatch": "^4.0.4"
	},
	"engines": {
		"node": "^24.0.0 || >=26.0.0"
	},
	"packageManager": "bun@1.3.14",
	"trustedDependencies": [
		"esbuild",
		"unrs-resolver"
	]
}
